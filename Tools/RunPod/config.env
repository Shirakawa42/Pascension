# RunPod config for SoiSim CPU fan-out — NON-SECRET values only.
# Secrets live in the repo-root .env (gitignored): RUNPOD_API_KEY, RUNPOD_S3_KEY.
# The S3 access key ID is the account user id, fetched from the API at runtime.
RUNPOD_VOLUME_ID=y5sq7dor3t
RUNPOD_DATACENTER=EU-CZ-1
RUNPOD_S3_ENDPOINT=https://s3api-eu-cz-1.runpod.io
# Cost guards (the orchestrator enforces these):
RUNPOD_MAX_PODS=55
RUNPOD_MAX_POD_MINUTES=90
