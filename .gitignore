# OS
.DS_Store
Thumbs.db

# Crash reports
sysinfo.txt
crashlytics-build.properties

# Generated MCP state
Library/MCPForUnity/
[Bb]in/
Tools/**/obj/
Tools/**/bin/

# graphify knowledge graph (generated, machine-local — rebuild with /graphify Assets/Scripts)
graphify-out/
# The post-commit hook stub-rebuilds into Assets/Scripts/graphify-out (root-resolution
# quirk); the dir matches the pattern above but Unity's .meta for it does not.
Assets/Scripts/graphify-out.meta

# SoiSim raw simulation output (reproducible from seeds; reports are committed instead)
Tools/ShardsData/sim/
# Live campaign status (machine-local heartbeat; history is campaign-log.md)
Tools/ShardsData/campaign-status.md
# Neural self-play position data (gigabytes; regenerable from seeds)
Tools/ShardsData/selfplay/
Tools/ShardsData/selfplay2/
# Python env + raw training outputs (weights are committed via ShardsNetWeights.g.cs)
Tools/ShardsML/.venv/
Tools/ShardsML/out/

# Assets/Art/Shards/ holds ORIGINAL Anima-generated card art (committed).
# If official card images are ever imported over it (Pascension/Setup/Shards
# Art Import), those are PERSONAL USE ONLY — re-add the ignore, never commit them.
